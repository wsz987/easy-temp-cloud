# Public address clients use to retrieve the returned URL. Set this to your LAN/domain address.
PUBLIC_BASE_URL=http://localhost:8080

# Host port published to the host machine (container still listens on 8080).
# Change this to expose the service on a different port, e.g. HOST_PORT=9090.
HOST_PORT=8080

# Required short access password: 6-16 printable ASCII characters.
AUTH_PASSWORD=eztCloud@

# Per-file upload cap (must not exceed 10 GiB). Supports raw bytes, MiB, MB, GiB, GB, m, or g.
MAX_UPLOAD_BYTES=10GiB
# Combined size of unique, unexpired files (must not exceed 10 GiB). New unique files receive HTTP 507 when full.
MAX_STORAGE_BYTES=10GiB
# File retention. Positive integer plus: m (minutes), h (hours), d (days), or w (weeks).
RETENTION=1d

# Which upload content types are accepted.
#   images   = JPEG, PNG, GIF, WebP
#   all      = accept any content type, no validation
#   videos   = MP4, WebM, MOV, MKV, AVI, MPEG
#   audio    = MP3, OGG, WAV, WebM audio, AAC, FLAC
#   docs     = PDF, plain text, Markdown, HTML
# Or build your own comma-separated list, mixing aliases, prefix
# wildcards, and exact MIME types, e.g.
#   ALLOWED_TYPES=images,videos,image/*,application/pdf
ALLOWED_TYPES=all

# Set STORAGE_DRIVER=oss only after filling every OSS_* setting below.
STORAGE_DRIVER=local
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
